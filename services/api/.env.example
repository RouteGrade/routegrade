# RouteGrade API — copy to `.env` and fill in real values. Never commit `.env`.

# --- Database ---------------------------------------------------------------
# Use the Supabase pooled connection string (see docs/supabase-setup.md).
# For local Postgres: postgresql+psycopg://user:pass@localhost:5432/routegrade
DATABASE_URL=

# --- Supabase JWT verification ---------------------------------------------
SUPABASE_URL=
# Exact `iss` claim we expect on issued tokens.
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
# JWKS endpoint for asymmetric key verification.
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
# Comma-separated allowed algorithms. Symmetric algs are intentionally excluded.
SUPABASE_JWT_ALGORITHMS=RS256,ES256

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000

# --- Route planning providers (MVP 3) ----------------------------------------
# Defaults are public keyless OSM-ecosystem endpoints — fine for local dev,
# NOT for production traffic. See docs/routing-setup.md.
# Nominatim-compatible geocoder (self-host or swap for a managed provider).
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=RouteGrade/0.1 (contact: you@example.com)
# OSRM HTTP API. Self-host with the `foot` profile for real runs; the public
# demo server only serves `driving`.
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_PROFILE=foot
# Open-Elevation-compatible endpoint.
ELEVATION_BASE_URL=https://api.open-elevation.com
PROVIDER_TIMEOUT_SECONDS=10
# Accepted relative deviation between requested and generated distance.
ROUTE_PLAN_DISTANCE_TOLERANCE=0.10
# Per-IP rate limit on POST /v1/routes/plan (sustained/min + burst headroom; 0 disables).
ROUTE_PLAN_RATE_LIMIT_PER_MINUTE=10
ROUTE_PLAN_RATE_LIMIT_BURST=5
