# RouteGrade API — copy to `.env` and fill in real values. Never commit `.env`.

# --- Database ---------------------------------------------------------------
# Use the Supabase pooled connection string (see docs/supabase-setup.md).
# For local Postgres: postgresql+psycopg://user:pass@localhost:5432/routegrade
DATABASE_URL=

# --- Supabase JWT verification ---------------------------------------------
SUPABASE_URL=
# Exact `iss` claim we expect on issued tokens.
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
# JWKS endpoint for asymmetric key verification.
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
# Comma-separated allowed algorithms. Symmetric algs are intentionally excluded.
SUPABASE_JWT_ALGORITHMS=RS256,ES256

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000
