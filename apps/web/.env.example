# Copy to `.env.local` (git-ignored) and fill in the real values.

# --- FastAPI health proxy (MVP 1) -----------------------------------------
API_URL=http://127.0.0.1:8000

# --- MapLibre style URL ----------------------------------------------------
# OpenFreeMap and the MapLibre demo style are for local development only.
# See root README for the production tile-provider warning.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark

# --- Supabase Auth (MVP 2) -------------------------------------------------
# From the Supabase dashboard -> Project Settings -> API.
# Use the PUBLISHABLE (anon) key here — never the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Frontend -> FastAPI ---------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public origin the browser uses to construct auth redirect URLs. In dev, keep
# the localhost default. In Vercel production set this to the deployed origin
# (https://routegrade-web.vercel.app). If unset in production the browser
# falls back to `window.location.origin` — the flow still works — but keeping
# this explicit avoids drift between deploys and previews.
NEXT_PUBLIC_APP_URL=http://localhost:3000
